@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>LifeNest Women’s Clinic | OB-GYN Care and Women’s Health</PageTitle>
<HeadContent>
    <meta name="description" content="LifeNest Women’s Clinic provides compassionate OB-GYN care, pregnancy checkups, prenatal care, gynecology consultation, and women’s health services." />
    <link rel="canonical" href="https://lifenestclinic.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="LifeNest Women’s Clinic | OB-GYN Care and Women’s Health" />
    <meta property="og:description" content="Compassionate OB-GYN care, pregnancy support, and women’s health services for every stage of life." />
    <meta property="og:url" content="https://lifenestclinic.com/" />
    <meta property="og:image" content="https://lifenestclinic.com/images/clinic/hero-consultation-user.jpg" />
    <script type="application/ld+json">@((MarkupString)SchemaJson)</script>
</HeadContent>

<div class="site-shell">
    <div class="contact-bar">
        <div class="container contact-bar__inner">
            <span>Mon–Fri: 9:00 AM–5:00 PM · Sat: 9:00 AM–2:00 PM</span>
            <div class="contact-bar__details">
                <a href="tel:+639178245631">☎ +63 917 824 5631</a>
                <a href="mailto:care@lifenestwomensclinic.com">✉ care@lifenestwomensclinic.com</a>
                <span>⌖ San Jose del Monte, Bulacan</span>
            </div>
        </div>
    </div>

    <header class="site-header">
        <div class="container navbar">
            <a class="brand" href="#home" aria-label="LifeNest Women’s Clinic home">
                <img class="brand__logo" src="images/lifenest-logo-final-transparent.png" alt="" aria-hidden="true" />
                <span><strong>LifeNest</strong><small>Women’s Clinic</small></span>
            </a>
            <div class="navbar-actions">
                <a class="button button--small header-appointment" href="#appointment">Appointment</a>
                <button class="menu-toggle" type="button" aria-label="Toggle navigation" aria-expanded="@(menuOpen ? "true" : "false")" @onclick="ToggleMenu">
                    <span></span><span></span><span></span>
                </button>
            </div>
            <nav class="mobile-nav @(menuOpen ? "is-open" : null)" aria-label="Mobile navigation">
                <a href="#home" @onclick="CloseMenu">Home</a>
                <a href="#about" @onclick="CloseMenu">Clinic</a>
                <a href="#services" @onclick="CloseMenu">Services</a>
                <a href="#doctor" @onclick="CloseMenu">Doctor</a>
                <a href="#schedule" @onclick="CloseMenu">Schedule</a>
                <a href="#faq" @onclick="CloseMenu">FAQs</a>
                <a href="#contact" @onclick="CloseMenu">Contact</a>
                <a class="button button--small" href="#appointment" @onclick="CloseMenu">Appointment</a>
            </nav>
        </div>
    </header>

    <nav class="desktop-side-nav" aria-label="Section navigation">
        <a href="#home" aria-label="Home"><span aria-hidden="true">⌂</span><strong>Home</strong></a>
        <a href="#about" aria-label="Our Clinic"><span aria-hidden="true">◇</span><strong>Our Clinic</strong></a>
        <a href="#services" aria-label="Care Services"><span aria-hidden="true">✚</span><strong>Care Services</strong></a>
        <a href="#doctor" aria-label="Meet the Doctor"><span aria-hidden="true">⚕</span><strong>Meet the Doctor</strong></a>
        <a href="#schedule" aria-label="Clinic Schedule"><span aria-hidden="true">◷</span><strong>Schedule</strong></a>
        <a href="#faq" aria-label="Patient FAQs"><span aria-hidden="true">?</span><strong>FAQs</strong></a>
        <a href="#contact" aria-label="Contact Us"><span aria-hidden="true">✉</span><strong>Contact</strong></a>
    </nav>

    <aside class="floating-contact" aria-label="Quick clinic contact actions">
        <span class="floating-contact__label">Quick contact</span>
        <a href="tel:+639178245631" aria-label="Call LifeNest Women’s Clinic at +63 917 824 5631"><span>☎</span><strong>Call</strong></a>
        <a href="mailto:care@lifenestwomensclinic.com" aria-label="Email LifeNest Women’s Clinic"><span>✉</span><strong>Message</strong></a>
    </aside>

    <main>
        <section class="hero" id="home">
            <div class="hero__orb hero__orb--one"></div><div class="hero__orb hero__orb--two"></div>
            <div class="container hero__grid">
                <div class="hero__content reveal">
                    <p class="eyebrow"><span></span> Care that listens. Support that stays.</p>
                    <h1>Compassionate OB-GYN Care for Every Stage of <em>Womanhood</em></h1>
                    <p class="hero__lead">Personalized women’s health, pregnancy care, and consultation in a calm and respectful clinic setting.</p>
                    <div class="hero__actions">
                        <a class="button" href="#appointment">Book Appointment <span>→</span></a>
                        <a class="button button--ghost" href="#services">View Services</a>
                    </div>
                    <div class="trust-row" aria-label="Clinic qualities">
                        <span>✓ Licensed OB-GYN Care</span><span>✓ Private Consultation</span><span>✓ Patient-Centered Care</span>
                    </div>
                </div>
                <div class="hero__visual reveal">
                    <div class="hero-photo photo-placeholder--hero">
                        <img class="clinic-image" src="images/clinic/hero-consultation-user.jpg" alt="OB-GYN doctor consulting with a pregnant patient in a private clinic room" />
                        <div class="hero-photo__caption"><span>Private, respectful care</span><strong>A calm space to ask questions</strong></div>
                        <div class="care-note"><span class="care-note__icon">✓</span><span><strong>Professional care</strong><small>Patient privacy respected</small></span></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="quick-info" aria-label="Clinic information">
            <div class="container quick-info__heading"><h2>Plan Your Visit with Confidence</h2><p>Helpful clinic details for appointments, schedules, and patient inquiries.</p></div>
            <div class="container quick-info__grid">
                @foreach (var item in QuickInfo)
                {
                    <article class="info-card"><span class="info-card__icon">@item.Icon</span><div><small>@item.Label</small><strong>@item.Value</strong><a href="@item.Link">@item.Action →</a></div></article>
                }
            </div>
        </section>

        <section class="section" id="about">
            <div class="container split-layout">
                <div class="section-inline-heading about-heading reveal">
                    <p class="eyebrow"><span></span> About LifeNest</p>
                    <h2>Women’s Health Care with Comfort and Respect</h2>
                    <p class="section-subtitle">LifeNest Women’s Clinic provides patient-centered support for women, mothers, and growing families.</p>
                </div>
                <div class="about-visual reveal">
                    <div class="image-placeholder image-placeholder--photo">
                        <img class="clinic-image" src="images/clinic/clinic-consultation-room-user.jpg" alt="Bright, private, and comfortable women’s health consultation room" />
                    </div>
                    <div class="experience-card"><strong>Private</strong><span>Respectful consultations in a calm, safe setting</span></div>
                </div>
                <div class="section-copy reveal">
                    <p>LifeNest Women’s Clinic is a welcoming space for women seeking thoughtful medical guidance, pregnancy care, and gynecology support. We believe every patient deserves to feel heard, informed, and comfortable.</p>
                    <p>From routine consultation to prenatal and postpartum care, we protect your privacy and support your choices with professional, compassionate attention.</p>
                    <div class="feature-list">
                        <span><b>✓</b> Respectful, private consultations</span><span><b>✓</b> Support through every life stage</span><span><b>✓</b> Clear, patient-friendly guidance</span><span><b>✓</b> Calm and comfortable environment</span>
                    </div>
                    <a class="text-link" href="#doctor">Meet your doctor <span>→</span></a>
                </div>
            </div>
        </section>

        <section class="section section--compact" id="why-lifenest">
            <div class="container">
                <div class="section-heading section-heading--center reveal"><div><p class="eyebrow"><span></span> Why LifeNest</p><h2>Why Patients Choose LifeNest</h2></div><p>A calm, private, and professional clinic experience focused on women’s health and pregnancy care.</p></div>
                <div class="why-grid card-grid--collapsible @(whyExpanded ? "is-expanded" : null)" id="why-cards">
                    @foreach (var reason in GetVisibleItems(Reasons, whyExpanded, whyVisibleCount))
                    {
                        <article class="why-card reveal"><span class="why-card__number">@reason.Number</span><span class="why-card__icon">@reason.Icon</span><h3>@reason.Title</h3><p>@reason.Description</p></article>
                    }
                </div>
                @if (ShouldShowToggle(Reasons, whyVisibleCount))
                {
                    <div class="card-toggle-wrap"><button class="button button--ghost card-toggle" type="button" aria-controls="why-cards" aria-expanded="@whyExpanded.ToString().ToLowerInvariant()" @onclick="ToggleWhy">@(whyExpanded ? "Show Less" : "Show More")</button></div>
                }
            </div>
        </section>

        <section class="section section--tint" id="services">
            <div class="container">
                <div class="section-heading reveal"><div><p class="eyebrow"><span></span> Women’s health services</p><h2>OB-GYN Services Offered</h2></div><p>Essential women’s health services delivered with care, clarity, and professionalism.</p></div>
                <div class="services-grid card-grid--collapsible @(servicesExpanded ? "is-expanded" : null)" id="service-cards">
                    @foreach (var service in GetVisibleItems(Services, servicesExpanded, servicesVisibleCount))
                    {
                        <article class="service-card service-card--icon reveal"><span class="service-card__badge">Women’s care</span><span class="service-card__icon">@service.Icon</span><h3>@service.Title</h3><p>@service.Description</p><a href="#appointment" aria-label="Book @service.Title">Learn more <span>→</span></a></article>
                    }
                </div>
                @if (ShouldShowToggle(Services, servicesVisibleCount))
                {
                    <div class="card-toggle-wrap"><button class="button button--ghost card-toggle" type="button" aria-controls="service-cards" aria-expanded="@servicesExpanded.ToString().ToLowerInvariant()" @onclick="ToggleServices">@(servicesExpanded ? "Show Less" : "Show More")</button></div>
                }
            </div>
        </section>

        <section class="section" id="doctor">
            <div class="container doctor-card reveal">
                <div class="section-inline-heading doctor-heading">
                    <p class="eyebrow"><span></span> Your specialist</p>
                    <h2>Meet Your OB-GYN Specialist</h2>
                    <p class="section-subtitle">Dedicated care from Dr. Maria Clara Delo Santos for women’s health and pregnancy concerns.</p>
                </div>
                <div class="doctor-photo doctor-photo--real">
                    <img class="clinic-image" src="images/clinic/doctor-maria-santos-user.jpg" alt="Portrait of Dr. Maria Clara Delo Santos, OB-GYN Specialist" />
                </div>
                <div class="doctor-info">
                    <h3 class="doctor-name">Dr. Maria Clara Delo Santos</h3><p class="doctor-role">OB-GYN Specialist</p>
                    <p>Dedicated to helping women feel confident and cared for, Dr. Maria Clara Delo Santos provides attentive consultations and evidence-informed care in a respectful, reassuring environment.</p>
                    <div class="doctor-details"><div><small>Specialty</small><strong>OB-GYN Specialist</strong></div><div><small>Care focus</small><strong>Women’s Health &amp; Pregnancy Care</strong></div><div><small>Experience</small><strong>12+ Years of Women’s Health Care Experience</strong></div><div><small>Clinic schedule</small><strong>Monday–Saturday · Sunday by appointment</strong></div></div>
                    <a class="button" href="#appointment">Schedule a Visit <span>→</span></a>
                </div>
            </div>
        </section>

        <section class="section confidence-section section--tint" aria-labelledby="confidence-title">
            <div class="container"><div class="section-heading section-heading--center reveal"><div><p class="eyebrow"><span></span> Patient experience</p><h2 id="confidence-title">Patient Experience and Care Feedback</h2></div><p>Sample feedback showing the kind of calm, respectful, and professional experience LifeNest aims to provide.</p></div><div class="testimonial-grid card-grid--collapsible @(testimonialsExpanded ? "is-expanded" : null)" id="testimonial-cards">
                @foreach (var testimonial in GetVisibleItems(Testimonials, testimonialsExpanded, testimonialsVisibleCount))
                {
                    <article class="testimonial-card reveal"><div class="testimonial-card__top"><span class="testimonial-avatar">@testimonial.Initials</span><span><strong>@testimonial.Name</strong><small>@testimonial.Label</small></span><b aria-label="Five-star feedback sample">★★★★★</b></div><blockquote>“@testimonial.Quote”</blockquote><span class="quote-mark">”</span></article>
                }
            </div>
            @if (ShouldShowToggle(Testimonials, testimonialsVisibleCount))
            {
                <div class="card-toggle-wrap"><button class="button button--ghost card-toggle" type="button" aria-controls="testimonial-cards" aria-expanded="@testimonialsExpanded.ToString().ToLowerInvariant()" @onclick="ToggleTestimonials">@(testimonialsExpanded ? "Show Less" : "Show More")</button></div>
            }
            <p class="sample-note">Patient feedback samples are for website preview purposes.</p></div>
        </section>

        <section class="section section--blue" id="schedule">
            <div class="container schedule-layout">
                <div class="schedule-intro"><p class="eyebrow eyebrow--light"><span></span> Visit planning</p><h2>Clinic Schedule and Visit Hours</h2><p>Plan your consultation ahead and confirm doctor availability before visiting.</p><div class="schedule-trust"><span>✓ Private consultations</span><span>✓ Confirmed appointment times</span></div><a class="button button--white" href="#appointment">Request Appointment</a></div>
                <div class="schedule-card">
                    <div class="schedule-card__header"><span class="schedule-card__icon">◷</span><div><small>Weekly consultation hours</small><strong>LifeNest Women’s Clinic</strong></div><span class="schedule-card__status">Open weekly</span></div>
                    <div class="schedule-row"><span><small>Weekdays</small>Monday to Friday</span><strong>9:00 AM – 5:00 PM</strong></div>
                    <div class="schedule-row"><span><small>Weekend</small>Saturday</span><strong>9:00 AM – 2:00 PM</strong></div>
                    <div class="schedule-row"><span><small>Sunday</small>By Appointment Only</span><strong>Contact Clinic</strong></div>
                    <p class="schedule-note"><span>i</span>Please contact the clinic to confirm doctor availability before visiting.</p>
                </div>
            </div>
        </section>

        <section class="section clinic-gallery" id="gallery">
            <div class="container">
                <div class="section-heading reveal"><div><p class="eyebrow"><span></span> Our clinic environment</p><h2>A Calm and Comfortable Clinic Environment</h2></div><p>Designed to provide a clean, private, and welcoming space for every patient visit.</p></div>
                <div class="gallery-grid card-grid--collapsible @(galleryExpanded ? "is-expanded" : null)" id="gallery-cards">
                    @foreach (var space in GetVisibleItems(ClinicSpaces, galleryExpanded, galleryVisibleCount))
                    {
                        <figure class="gallery-card @space.ClassName reveal"><img class="clinic-image" src="@space.ImagePath" alt="@space.Title at LifeNest Women’s Clinic" /><figcaption><span>@space.Number</span><strong>@space.Title</strong><small>@space.Description</small></figcaption></figure>
                    }
                </div>
                @if (ShouldShowToggle(ClinicSpaces, galleryVisibleCount))
                {
                    <div class="card-toggle-wrap"><button class="button button--ghost card-toggle" type="button" aria-controls="gallery-cards" aria-expanded="@galleryExpanded.ToString().ToLowerInvariant()" @onclick="ToggleGallery">@(galleryExpanded ? "Show Less" : "Show More")</button></div>
                }
            </div>
        </section>

        <section class="section" id="appointment">
            <div class="container appointment-layout">
                <div class="appointment-copy"><p class="eyebrow"><span></span> Appointment request</p><h2>Request an Appointment</h2><p>Send your preferred visit details and the clinic team will guide you through the next steps.</p><div class="appointment-photo photo-placeholder appointment-photo--real"><img class="clinic-image" src="images/clinic/appointment-exam-room-user.jpg" alt="Clean and comfortable women’s clinic examination room prepared for an appointment" /><div class="privacy-seal"><b>⌾</b><span><strong>Privacy matters</strong>Your appointment request is treated with privacy and care.</span></div></div><div class="contact-stack"><span><b>☎</b><small>Primary phone</small><strong>+63 917 824 5631</strong></span><span><b>☎</b><small>Secondary phone</small><strong>+63 2 8456 2034</strong></span><span><b>✉</b><small>Appointments</small><strong>appointments@lifenestwomensclinic.com</strong></span><span><b>⌖</b><small>Visit us</small><strong>Suite 204, Aurora Medical Plaza<br />Quirino Highway, San Jose del Monte<br />Bulacan, Philippines</strong></span></div></div>
                <div class="form-card">
                    <form class="appointment-form" action="https://api.staticforms.dev/submit" method="post" novalidate>
                        <!-- The real Static Forms API key is injected during GitHub Actions deployment using the STATIC_FORMS_API_KEY repository secret. -->
                        <input type="hidden" name="apiKey" value="__STATIC_FORMS_API_KEY__" />
                        <input type="hidden" name="subject" value="New LifeNest Appointment Request" />
                        <div class="form-grid"><label>Full Name<input name="name" required autocomplete="name" placeholder="Your full name" /></label><label>Contact Number<input name="phone" required type="tel" autocomplete="tel" placeholder="Your phone number" /></label><label>Preferred Date<input name="preferredDate" required type="date" /></label><label>Preferred Time<select name="preferredTime" required><option value="">Select a time</option><option>Morning</option><option>Afternoon</option></select></label><label class="full">Service Needed<select name="service" required><option value="">Select a service</option>@foreach (var service in Services){<option>@service.Title</option>}</select></label><label class="full">Message<textarea name="message" rows="4" placeholder="How can we help? (Optional)"></textarea></label></div>
                        <input type="text" name="honeypot" class="form-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
                        <button class="button button--wide" type="submit" data-submit-label="Request Appointment">Request Appointment <span>→</span></button>
                        <p class="form-status" id="appointment-form-status" role="status" aria-live="polite"></p>
                        <small class="privacy-note">⌾ Your appointment request is treated with privacy and care.</small>
                    </form>
                </div>
            </div>
        </section>

        <section class="section section--tint" id="faq">
            <div class="container faq-layout"><div><p class="eyebrow"><span></span> Patient information</p><h2>Common Questions Before Your Visit</h2><p>Quick answers to help patients prepare for consultation.</p><a class="text-link" href="#contact">Contact the clinic <span>→</span></a></div><div class="faq-list">
                @for (var index = 0; index < Faqs.Length; index++)
                {
                    var faqIndex = index;
                    var faq = Faqs[faqIndex];
                    <div class="faq-item @(openFaq == faqIndex ? "is-open" : null)">
                        <button type="button" aria-expanded="@(openFaq == faqIndex ? "true" : "false")" aria-controls="faq-answer-@faqIndex" @onclick="() => ToggleFaq(faqIndex)"><span>@faq.Question</span><b aria-hidden="true">+</b></button>
                        <div class="faq-answer" id="faq-answer-@faqIndex" aria-hidden="@(openFaq == faqIndex ? "false" : "true")"><p>@faq.Answer</p></div>
                    </div>
                }
            </div></div>
        </section>
    </main>

    <footer id="contact">
        <div class="container footer-grid"><div><a class="brand brand--footer" href="#home"><img class="brand__logo" src="images/lifenest-logo-final-transparent.png" alt="" aria-hidden="true" /><span><strong>LifeNest</strong><small>Women’s Clinic</small></span></a><p>LifeNest Women’s Clinic provides compassionate OB-GYN care, pregnancy consultation, and women’s health support in a calm and respectful setting.</p></div><div><h3>Quick links</h3><a href="#about">About</a><a href="#services">Services</a><a href="#doctor">Doctor</a><a href="#appointment">Appointment</a></div><div><h3>Clinic</h3><span>Suite 204, Aurora Medical Plaza<br />Quirino Highway, San Jose del Monte<br />Bulacan, Philippines</span><a href="tel:+639178245631">+63 917 824 5631</a><a href="tel:+63284562034">+63 2 8456 2034</a><a href="mailto:care@lifenestwomensclinic.com">care@lifenestwomensclinic.com</a></div><div><h3>Hours</h3><span>Monday–Friday: 9:00 AM–5:00 PM</span><span>Saturday: 9:00 AM–2:00 PM</span><span>Sunday: By Appointment Only</span></div></div>
        <div class="container footer-bottom"><span>© @DateTime.Now.Year LifeNest Women’s Clinic. All rights reserved.</span><span>Privacy-friendly care · Placeholder clinic information</span></div>
    </footer>
</div>

<div class="appointment-success-modal" id="appointment-success-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="appointment-success-title">
    <div class="appointment-success-panel" role="document">
        <button class="appointment-success-close" type="button" aria-label="Close appointment confirmation">×</button>
        <span class="success-icon" aria-hidden="true">✓</span>
        <p class="eyebrow"><span></span> Request sent</p>
        <h2 id="appointment-success-title">Thank you for your appointment request!</h2>
        <p>Your details were sent successfully. The LifeNest clinic team will contact you to confirm availability.</p>
        <button class="button appointment-success-close" type="button">Close</button>
        <small>Your request will be reviewed with privacy and care.</small>
    </div>
</div>

@code {
    private IJSObjectReference? navigationModule;
    private bool menuOpen;
    private bool whyExpanded;
    private bool servicesExpanded;
    private bool testimonialsExpanded;
    private bool galleryExpanded;
    private int whyVisibleCount = 4;
    private int servicesVisibleCount = 4;
    private int testimonialsVisibleCount = 3;
    private int galleryVisibleCount = 4;
    private DotNetObjectReference<Home>? cardVisibilityReference;
    private int? openFaq;
    private void ToggleMenu() => menuOpen = !menuOpen;
    private void CloseMenu() => menuOpen = false;
    private void ToggleWhy() => whyExpanded = !whyExpanded;
    private void ToggleServices() => servicesExpanded = !servicesExpanded;
    private void ToggleTestimonials() => testimonialsExpanded = !testimonialsExpanded;
    private void ToggleGallery() => galleryExpanded = !galleryExpanded;
    private void ToggleFaq(int index) => openFaq = openFaq == index ? null : index;

    private static IEnumerable<T> GetVisibleItems<T>(IReadOnlyList<T> items, bool expanded, int visibleCount) =>
        expanded ? items : items.Take(visibleCount);

    private static bool ShouldShowToggle<T>(IReadOnlyList<T> items, int visibleCount) =>
        items.Count > visibleCount;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        navigationModule = await JS.InvokeAsync<IJSObjectReference>("import", "./navigation.js");
        await navigationModule.InvokeVoidAsync("initializeSectionNavigation");

        cardVisibilityReference = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("clinicWorksCardVisibility.initialize", cardVisibilityReference);
    }

    [JSInvokable]
    public Task UpdateVisibleCounts(int why, int services, int testimonials, int gallery)
    {
        whyVisibleCount = Math.Max(1, why);
        servicesVisibleCount = Math.Max(1, services);
        testimonialsVisibleCount = Math.Max(1, testimonials);
        galleryVisibleCount = Math.Max(1, gallery);

        if (!ShouldShowToggle(Reasons, whyVisibleCount)) whyExpanded = false;
        if (!ShouldShowToggle(Services, servicesVisibleCount)) servicesExpanded = false;
        if (!ShouldShowToggle(Testimonials, testimonialsVisibleCount)) testimonialsExpanded = false;
        if (!ShouldShowToggle(ClinicSpaces, galleryVisibleCount)) galleryExpanded = false;

        return InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (navigationModule is not null)
        {
            try
            {
                await navigationModule.InvokeVoidAsync("disposeSectionNavigation");
                await navigationModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        if (cardVisibilityReference is null) return;

        try
        {
            await JS.InvokeVoidAsync("clinicWorksCardVisibility.dispose");
        }
        catch (JSDisconnectedException)
        {
        }

        cardVisibilityReference.Dispose();
    }

    private readonly record struct InfoItem(string Icon, string Label, string Value, string Action, string Link);
    private readonly record struct ServiceItem(string Icon, string Title, string Description);
    private readonly record struct ReasonItem(string Number, string Icon, string Title, string Description);
    private readonly record struct SpaceItem(string Number, string Title, string Description, string ClassName, string ImagePath);
    private readonly record struct TestimonialItem(string Initials, string Name, string Label, string Quote);
    private readonly record struct FaqItem(string Question, string Answer);

